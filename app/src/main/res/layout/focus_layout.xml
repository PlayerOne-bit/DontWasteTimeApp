<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/focus_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B">

    <!-- Header -->

    <LinearLayout
        android:id="@+id/focusHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@+id/space2"
        app:layout_constraintStart_toEndOf="@+id/space"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus"
            android:textColor="@color/white"
            android:textSize="30sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Block distractions and lock in" />
        </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/focusCardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="#141414"
        app:cardCornerRadius="10dp"
        app:layout_constraintEnd_toStartOf="@+id/space2"
        app:layout_constraintStart_toEndOf="@+id/space"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time to FOCUS"
                android:textSize="25sp"
                android:textColor="#3B82F6"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:id="@+id/focusState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOT STARTED"
                android:textColor="#66676E" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/focusCircularProgress"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:indicatorSize="100dp"
                app:trackThickness="10dp"
                app:trackColor="#33FFFFFF"
                app:indicatorColor="#3B82F6"
                android:progress="75"
                app:trackCornerRadius="0dp" />

            <TextView
                android:id="@+id/focusTimeRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="30m"
                android:textColor="@color/white"
                android:textSize="36sp" />

            <!-- Duration chips -->
            <LinearLayout
                android:id="@+id/depthLinearLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lightText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="#1F1F1F"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:textAlignment="center"
                    android:text="LIGHT"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/steadyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="#1F1F1F"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="STEADY"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/deepText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1F1F1F"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="DEEP"
                    android:textColor="@color/white" />

            </LinearLayout>
            <TextView
                android:id="@+id/contextDepth"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="DEPTH"/>
            <!-- Start / Stop button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/focusButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#3B82F6"
                app:cardCornerRadius="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Start Focus Session"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:visibility="gone"
        android:id="@+id/restCardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#141414"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/space2"
        app:layout_constraintStart_toEndOf="@+id/space"
        android:layout_marginBottom="80dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time to REST"
                android:textSize="25sp"
                android:textColor="#B8FF2F"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:id="@+id/restState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOT STARTED"
                android:textColor="#66676E" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/restCircularProgress"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:progress="95"
                app:indicatorColor="#B8FF2F"
                app:indicatorSize="100dp"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="0dp"
                app:trackThickness="10dp" />

            <TextView
                android:id="@+id/restTimeRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="5m"
                android:textColor="@color/white"
                android:textSize="36sp" />


            <!-- Start / Stop button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/restButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#B8FF2F"
                app:cardCornerRadius="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Start Rest Session"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_marginTop="20dp"
        android:id="@+id/textView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Apps that will be blocked temporarily"
        android:textColor="@color/white"

        android:textSize="18sp"
        app:layout_constraintEnd_toStartOf="@+id/space2"
        app:layout_constraintStart_toEndOf="@+id/space"
        app:layout_constraintTop_toBottomOf="@+id/focusHeader" />


        <ScrollView
            android:background="#101010"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/textView2"
            android:layout_width="0dp"
            android:layout_height="200dp"
            app:layout_constraintEnd_toStartOf="@+id/space2"
            app:layout_constraintStart_toEndOf="@+id/space">

            <LinearLayout
                android:id="@+id/focusAppContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>

        </ScrollView>

    <include layout="@layout/navigation_panel" />

    <Space
        android:id="@+id/space"
        android:layout_width="20dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Space
        android:id="@+id/space2"
        android:layout_width="20dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
